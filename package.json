{
  "name": "pm-copilot-mcp",
  "version": "0.1.0",
  "description": "AI-powered Product Management Operating System exposed as a Model Context Protocol (MCP) server.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "pm-copilot-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "product-management",
    "ai",
    "pm-copilot"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
